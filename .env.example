# Combined .env template for both Docker stacks.
#
# Copy to .env at the repo root (or /opt/dispatch/.env on the deploy host)
# and edit as needed. Both docker-compose.yml and docker-compose.forecasting.yml
# pick up .env automatically when invoked from the same directory.
#
# Defaults are baked into the compose files via ${VAR:-default}; any line
# left commented out here uses that default. Only uncomment what you need
# to override.
#
# Full reference: docs/deploy.md §"Environment variables".

# ──────────────────────────────────────────────────────────────────────
#  REQUIRED for the CSV replay setup (this branch's default)
# ──────────────────────────────────────────────────────────────────────
# Seed timestamp for current.json on first deploy. The daemon's
# monotonicity floor is this minus commit_hours. Must be older than
# csv_end − REPLAY_LOOKBACK_MONTHS, otherwise every replay forecast is
# rejected as already-processed and the daemon sits idle silently.
#
# With the bundled CSV (csv_end = 2026-03-01T22:00Z) this value is safe:
INIT_STATE_SOLVE_TIME=2025-12-01T00:00:00Z
#
# UNSET this entire line at live-feed cutover. The live producer writes
# solve_times near wall-clock, and init-state's default (now top-of-hour
# UTC) is correct there. See docs/deploy.md §"Replay vs. live-feed
# timestamps".


# ──────────────────────────────────────────────────────────────────────
#  Forecasting stack (docker-compose.forecasting.yml)
# ──────────────────────────────────────────────────────────────────────
# Forecast model: daily_naive | weekly_naive | combined_seasonal
#MODEL=combined_seasonal

# Forward forecast length per cycle, in hours.
#HORIZON_HOURS=35

# Size of the replay window before csv_end, in months.
#REPLAY_LOOKBACK_MONTHS=3

# Seconds between ticks. 3600 = real hourly cadence (3-month wall-clock
# replay of the 3-month window). Drop to ~60 for a fast demo; lower than
# the daemon's per-cycle wall time (~5–30 s) starts dropping intermediate
# solve_times because the scanner is newest-wins.
#TICK_INTERVAL_S=3600


# ──────────────────────────────────────────────────────────────────────
#  Optimization stack (docker-compose.yml)
# ──────────────────────────────────────────────────────────────────────
# Path to plant_config.json for multi-asset deployments. Unset = the
# bundled legacy default plant (1 HP + 1 boiler + 1 CHP + 1 storage).
#CONFIG_FILE=/shared/config/plant_config.json

# DA price source: live (SMARD HTTP, production default) or csv (offline).
# csv mode also needs a PRICES_PATH and a bind mount; see deploy.md
# §"Offline prices".
#PRICES_SOURCE=live

# Optimizer time resolution. Must remain quarterhour for hybrid mode
# (hourly demand + 15-min prices) which is the production target.
#RESOLUTION=quarterhour

# Resolution of the demand forecast. Matches the forecasting team's
# output (hourly).
#FORECAST_RESOLUTION=hour

# How often the daemon polls data/forecast/, in seconds.
#SCAN_INTERVAL_S=2

# Opt-in stale floor (hours). 0 = disabled, REQUIRED while the CSV replay
# is running (replay legitimately writes months-old solve_times — any
# positive value silently drops them all). At live-feed cutover set to
# e.g. 2 so a wedged upstream producer feeding hours-old forecasts is
# rejected. See deploy.md §"Foot-gun: STALE_GRACE_HOURS and the CSV
# replay are mutually exclusive".
#STALE_GRACE_HOURS=0
